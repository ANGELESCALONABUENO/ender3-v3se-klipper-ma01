===== Config file =====
[virtual_sdcard]
path = /home/pi/printer_data/gcodes
on_error_gcode = CANCEL_PRINT

[pause_resume]
recover_velocity = 25

[display_status]

[respond]

[gcode_macro CANCEL_PRINT]
description = Cancel the actual running print
rename_existing = CANCEL_PRINT_BASE
gcode = 
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE']|default({}) %}
	{% set allow_park = client.park_at_cancel|default(false)|lower == 'true' %}
	{% set retract = client.cancel_retract|default(5.0)|abs %}
	
	{% set park_x = "" if (client.park_at_cancel_x|default(none) is none)
	else "X=" ~ client.park_at_cancel_x %}
	{% set park_y = "" if (client.park_at_cancel_y|default(none) is none)
	else "Y=" ~ client.park_at_cancel_y %}
	{% set custom_park = park_x|length > 0 or park_y|length > 0 %}
	
	
	{% if printer['gcode_macro RESUME'].restore_idle_timeout > 0 %}
	SET_IDLE_TIMEOUT TIMEOUT={printer['gcode_macro RESUME'].restore_idle_timeout}
	{% endif %}
	{% if (custom_park or not printer.pause_resume.is_paused) and allow_park %} _TOOLHEAD_PARK_PAUSE_CANCEL {park_x} {park_y} {% endif %}
	_CLIENT_RETRACT LENGTH={retract}
	TURN_OFF_HEATERS
	M106 S0
	{client.user_cancel_macro|default("")}
	SET_GCODE_VARIABLE MACRO=RESUME VARIABLE=idle_state VALUE=False
	
	SET_PAUSE_NEXT_LAYER ENABLE=0
	SET_PAUSE_AT_LAYER ENABLE=0 LAYER=0
	CANCEL_PRINT_BASE

[gcode_macro PAUSE]
description = Pause the actual running print
rename_existing = PAUSE_BASE
gcode = 
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE']|default({}) %}
	{% set idle_timeout = client.idle_timeout|default(0) %}
	{% set temp = printer[printer.toolhead.extruder].target if printer.toolhead.extruder != '' else 0 %}
	{% set restore = False if printer.toolhead.extruder == ''
	else True  if params.RESTORE|default(1)|int == 1 else False %}
	
	SET_GCODE_VARIABLE MACRO=RESUME VARIABLE=last_extruder_temp VALUE="{{'restore': restore, 'temp': temp}}"
	
	{% if idle_timeout > 0 %}
	SET_GCODE_VARIABLE MACRO=RESUME VARIABLE=restore_idle_timeout VALUE={printer.configfile.settings.idle_timeout.timeout}
	SET_IDLE_TIMEOUT TIMEOUT={idle_timeout}
	{% endif %}
	PAUSE_BASE
	{client.user_pause_macro|default("")}
	_TOOLHEAD_PARK_PAUSE_CANCEL {rawparams}

[gcode_macro RESUME]
description = Resume the actual running print
rename_existing = RESUME_BASE
variable_last_extruder_temp = {'restore': False, 'temp': 0}
variable_restore_idle_timeout = 0
variable_idle_state = False
gcode = 
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE']|default({}) %}
	{% set velocity = printer.configfile.settings.pause_resume.recover_velocity %}
	{% set sp_move = client.speed_move|default(velocity) %}
	{% set runout_resume = True if client.runout_sensor|default("") == ""
	else True if not printer[client.runout_sensor].enabled
	else printer[client.runout_sensor].filament_detected %}
	{% set can_extrude = True if printer.toolhead.extruder == ''
	else printer[printer.toolhead.extruder].can_extrude %}
	{% set do_resume = False %}
	{% set prompt_txt = [] %}
	
	
	{% if printer.idle_timeout.state|upper == "IDLE" or idle_state %}
	SET_GCODE_VARIABLE MACRO=RESUME VARIABLE=idle_state VALUE=False
	{% if last_extruder_temp.restore %}
	
	RESPOND TYPE=echo MSG='{"Restoring \"%s\" temperature to %3.1f\u00B0C, this may take some time" % (printer.toolhead.extruder, last_extruder_temp.temp) }'
	M109 S{last_extruder_temp.temp}
	{% set do_resume = True %}
	{% elif can_extrude %}
	{% set do_resume = True %}
	{% else %}
	RESPOND TYPE=error MSG='{"Resume aborted !!! \"%s\" not hot enough, please heat up again and press RESUME" % printer.toolhead.extruder}'
	{% set _d = prompt_txt.append("\"%s\" not hot enough, please heat up again and press RESUME" % printer.toolhead.extruder) %}
	{% endif %}
	
	{% elif can_extrude %}
	{% set do_resume = True %}
	{% else %}
	RESPOND TYPE=error MSG='{"Resume aborted !!! \"%s\" not hot enough, please heat up again and press RESUME" % printer.toolhead.extruder}'
	{% set _d = prompt_txt.append("\"%s\" not hot enough, please heat up again and press RESUME" % printer.toolhead.extruder) %}
	{% endif %}
	{% if runout_resume %}
	{% if do_resume %}
	{% if restore_idle_timeout > 0 %} SET_IDLE_TIMEOUT TIMEOUT={restore_idle_timeout} {% endif %}
	{client.user_resume_macro|default("")}
	_CLIENT_EXTRUDE
	RESUME_BASE VELOCITY={params.VELOCITY|default(sp_move)}
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='{"Resume aborted !!! \"%s\" detects no filament, please load filament and press RESUME" % (client.runout_sensor.split(" "))[1]}'
	{% set _d = prompt_txt.append("\"%s\" detects no filament, please load filament and press RESUME" % (client.runout_sensor.split(" "))[1]) %}
	{% endif %}
	
	{% if not (runout_resume and do_resume) %}
	RESPOND TYPE=command MSG="action:prompt_begin RESUME aborted !!!"
	{% for element in prompt_txt %}
	RESPOND TYPE=command MSG='{"action:prompt_text %s" % element}'
	{% endfor %}
	RESPOND TYPE=command MSG="action:prompt_footer_button Ok|RESPOND TYPE=command MSG=action:prompt_end|info"
	RESPOND TYPE=command MSG="action:prompt_show"
	{% endif %}

[gcode_macro SET_PAUSE_NEXT_LAYER]
description = Enable a pause if the next layer is reached
gcode = 
	{% set pause_next_layer = printer['gcode_macro SET_PRINT_STATS_INFO'].pause_next_layer %}
	{% set ENABLE = params.ENABLE|default(1)|int != 0 %}
	{% set MACRO = params.MACRO|default(pause_next_layer.call, True) %}
	SET_GCODE_VARIABLE MACRO=SET_PRINT_STATS_INFO VARIABLE=pause_next_layer VALUE="{{ 'enable': ENABLE, 'call': MACRO }}"

[gcode_macro SET_PAUSE_AT_LAYER]
description = Enable/disable a pause if a given layer number is reached
gcode = 
	{% set pause_at_layer = printer['gcode_macro SET_PRINT_STATS_INFO'].pause_at_layer %}
	{% set ENABLE = params.ENABLE|int != 0 if params.ENABLE is defined
	else params.LAYER is defined %}
	{% set LAYER = params.LAYER|default(pause_at_layer.layer)|int %}
	{% set MACRO = params.MACRO|default(pause_at_layer.call, True) %}
	SET_GCODE_VARIABLE MACRO=SET_PRINT_STATS_INFO VARIABLE=pause_at_layer VALUE="{{ 'enable': ENABLE, 'layer': LAYER, 'call': MACRO }}"

[gcode_macro SET_PRINT_STATS_INFO]
rename_existing = SET_PRINT_STATS_INFO_BASE
description = Overwrite, to get pause_next_layer and pause_at_layer feature
variable_pause_next_layer = { 'enable': False, 'call': "PAUSE" }
variable_pause_at_layer = { 'enable': False, 'layer': 0, 'call': "PAUSE" }
gcode = 
	{% if pause_next_layer.enable %}
	RESPOND TYPE=echo MSG='{"%s, forced by pause_next_layer" % pause_next_layer.call}'
	{pause_next_layer.call}
	SET_PAUSE_NEXT_LAYER ENABLE=0
	{% elif pause_at_layer.enable and params.CURRENT_LAYER is defined and params.CURRENT_LAYER|int == pause_at_layer.layer %}
	RESPOND TYPE=echo MSG='{"%s, forced by pause_at_layer [%d]" % (pause_at_layer.call, pause_at_layer.layer)}'
	{pause_at_layer.call}
	SET_PAUSE_AT_LAYER ENABLE=0
	{% endif %}
	SET_PRINT_STATS_INFO_BASE {rawparams}

[gcode_macro _TOOLHEAD_PARK_PAUSE_CANCEL]
description = Helper: park toolhead used in PAUSE and CANCEL_PRINT
gcode = 
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE']|default({}) %}
	{% set velocity = printer.configfile.settings.pause_resume.recover_velocity %}
	{% set use_custom     = client.use_custom_pos|default(false)|lower == 'true' %}
	{% set custom_park_x  = client.custom_park_x|default(0.0) %}
	{% set custom_park_y  = client.custom_park_y|default(0.0) %}
	{% set park_dz        = client.custom_park_dz|default(2.0)|abs %}
	{% set sp_hop         = client.speed_hop|default(15) * 60 %}
	{% set sp_move        = client.speed_move|default(velocity) * 60 %}
	
	{% set origin    = printer.gcode_move.homing_origin %}
	{% set act       = printer.gcode_move.gcode_position %}
	{% set max       = printer.toolhead.axis_maximum %}
	{% set cone      = printer.toolhead.cone_start_z|default(max.z) %}
	{% set round_bed = True if printer.configfile.settings.printer.kinematics is in ['delta','polar','rotary_delta','winch']
	else False %}
	
	{% set z_min = params.Z_MIN|default(0)|float %}
	{% set z_park = [[(act.z + park_dz), z_min]|max, (max.z - origin.z)]|min %}
	{% set x_park = params.X       if params.X is defined
	else custom_park_x  if use_custom
	else 0.0            if round_bed
	else (max.x - 5.0) %}
	{% set y_park = params.Y       if params.Y is defined
	else custom_park_y  if use_custom
	else (max.y - 5.0)  if round_bed and z_park < cone
	else 0.0            if round_bed
	else (max.y - 5.0) %}
	
	_CLIENT_RETRACT
	{% if "xyz" in printer.toolhead.homed_axes %}
	G90
	G1 Z{z_park} F{sp_hop}
	G1 X{x_park} Y{y_park} F{sp_move}
	{% if not printer.gcode_move.absolute_coordinates %} G91 {% endif %}
	{% else %}
	RESPOND TYPE=echo MSG='Printer not homed'
	{% endif %}

[gcode_macro _CLIENT_EXTRUDE]
description = Extrudes, if the extruder is hot enough
gcode = 
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE']|default({}) %}
	{% set use_fw_retract = (client.use_fw_retract|default(false)|lower == 'true') and (printer.firmware_retraction is defined) %}
	{% set length = params.LENGTH|default(client.unretract)|default(1.0)|float %}
	{% set speed = params.SPEED|default(client.speed_unretract)|default(35) %}
	{% set absolute_extrude = printer.gcode_move.absolute_extrude %}
	
	{% if printer.toolhead.extruder != '' %}
	{% if printer[printer.toolhead.extruder].can_extrude %}
	{% if use_fw_retract %}
	{% if length < 0 %}
	G10
	{% else %}
	G11
	{% endif %}
	{% else %}
	M83
	G1 E{length} F{(speed|float|abs) * 60}
	{% if absolute_extrude %}
	M82
	{% endif %}
	{% endif %}
	{% else %}
	RESPOND TYPE=echo MSG='{"\"%s\" not hot enough" % printer.toolhead.extruder}'
	{% endif %}
	{% endif %}

[gcode_macro _CLIENT_RETRACT]
description = Retracts, if the extruder is hot enough
gcode = 
	{% set client = printer['gcode_macro _CLIENT_VARIABLE']|default({}) %}
	{% set length = params.LENGTH|default(client.retract)|default(1.0)|float %}
	{% set speed = params.SPEED|default(client.speed_retract)|default(35) %}
	
	_CLIENT_EXTRUDE LENGTH=-{length|float|abs} SPEED={speed|float|abs}

[gcode_macro _CLIENT_LINEAR_MOVE]
description = Linear move with save and restore of the gcode state
gcode = 
	{% set x_move = "X" ~ params.X if params.X is defined else "" %}
	{% set y_move = "Y" ~ params.Y if params.Y is defined else "" %}
	{% set z_move = "Z" ~ params.Z if params.Z is defined else "" %}
	{% set e_move = "E" ~ params.E if params.E is defined else "" %}
	{% set rate = "F" ~ params.F if params.F is defined else "" %}
	{% set ABSOLUTE = params.ABSOLUTE | default(0) | int != 0 %}
	{% set ABSOLUTE_E = params.ABSOLUTE_E | default(0) | int != 0 %}
	SAVE_GCODE_STATE NAME=_client_movement
	{% if x_move or y_move or z_move %}
	G9{ 0 if ABSOLUTE else 1 }
	{% endif %}
	{% if e_move %}
	M8{ 2 if ABSOLUTE_E else 3 }
	{% endif %}
	G1 { x_move } { y_move } { z_move } { e_move } { rate }
	RESTORE_GCODE_STATE NAME=_client_movement

[gcode_macro MATERIAL_Z_OFFSET]
description = Valores de ajuste Z por material
variable_pla = 0.15
variable_abs = -0.1
variable_tpu = 0.10
gcode = 
	{ action_respond_info("MATERIAL_Z_OFFSET: PLA=" ~ pla ~ " ABS=" ~ abs ~ " TPU=" ~ tpu) }

[gcode_macro APPLY_MATERIAL_Z_OFFSET]
description = Aplica Z-offset desde Spoolman (fallback a tabla local PLA/ABS/TPU)
gcode = 
	{% set material_hint = params.MATERIAL|default(printer["gcode_macro MATERIAL_RUNTIME"].material_name|default(""))|string|upper %}
	{% set sp_synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|default(0)|int %}
	{% set sp_delta = printer["gcode_macro SPOOLMAN_ACTIVE"].z_offset|default(999.0)|float %}
	{% set has_spoolman_z = (sp_synced == 1 and sp_delta > -2.0 and sp_delta < 2.0) %}
	{% set delta = 0.0 %}
	{% set source = "local" %}
	
	{% if has_spoolman_z %}
	{% set delta = sp_delta %}
	{% set source = "Spoolman" %}
	{% else %}
	{% if "PLA" in material_hint %}
	{% set delta = printer["gcode_macro MATERIAL_Z_OFFSET"].pla|float %}
	{% elif "ABS" in material_hint %}
	{% set delta = printer["gcode_macro MATERIAL_Z_OFFSET"].abs|float %}
	{% elif "TPU" in material_hint %}
	{% set delta = printer["gcode_macro MATERIAL_Z_OFFSET"].tpu|float %}
	{% endif %}
	{% endif %}
	
	
	SET_GCODE_OFFSET Z=0 MOVE=0
	
	{% if delta != 0.0 %}
	SET_GCODE_OFFSET Z_ADJUST={delta} MOVE=0
	{% endif %}
	{ action_respond_info("Z_OFFSET aplicado (" ~ source ~ "): " ~ ("%+.3f" % delta)) }

[gcode_macro DESTRABAR_BLTOUCH]
description = Destrabe de BLTouch/CRTouch con calor + vibracion controlada en eje X
gcode = 
	{% set target = params.TARGET|default(200)|float %}
	{% set cycles = params.CYCLES|default(40)|int %}
	{% set amp = params.AMP|default(8.0)|float %}
	{% set feed = params.FEED|default(900)|float %}
	
	{% set x_min = printer.toolhead.axis_minimum.x|float %}
	{% set x_max = printer.toolhead.axis_maximum.x|float %}
	{% set x_safe_left = x_min + 10.0 %}
	{% set x_safe_right = x_max - 10.0 %}
	{% set max_amp = (x_safe_right - x_safe_left) / 2.0 %}
	{% set amp = [amp, max_amp]|min %}
	
	{% if amp < 1.0 %}
	{ action_respond_info("DESTRABAR_BLTOUCH cancelado: rango X disponible demasiado corto") }
	{% else %}
	{ action_respond_info("DESTRABAR_BLTOUCH: objetivo hotend=" ~ target ~ "C, fan=100%, ciclos=" ~ cycles ~ ", amp=" ~ amp ~ "mm") }
	
	G28 X
	
	M104 S{target}
	M106 S255
	
	G90
	{% set base = x_safe_right - amp %}
	G1 X{base} F6000
	
	M109 S{target}
	
	BLTOUCH_DEBUG COMMAND=reset
	G4 P300
	BLTOUCH_DEBUG COMMAND=pin_down
	G4 P300
	BLTOUCH_DEBUG COMMAND=pin_up
	G4 P300
	
	G91
	{% for _ in range(cycles) %}
	G1 X{amp} F{feed}
	G1 X-{amp} F{feed}
	{% endfor %}
	G90
	
	BLTOUCH_DEBUG COMMAND=reset
	G4 P300
	BLTOUCH_DEBUG COMMAND=pin_down
	G4 P300
	BLTOUCH_DEBUG COMMAND=pin_up
	
	{ action_respond_info("DESTRABAR_BLTOUCH finalizado. Prueba: PROBE o G28") }
	{% endif %}

[gcode_macro PROBE_RECOVERY_PREPARE]
description = Recuperacion preventiva del probe antes de homing o calibracion
variable_enabled = 0
gcode = 
	{% set enabled = params.ENABLED|default(printer["gcode_macro PROBE_RECOVERY_PREPARE"].enabled)|int %}
	{% if enabled == 1 %}
	{% set target = params.TARGET|default(printer.extruder.target|default(200))|float %}
	{% set cycles = params.CYCLES|default(24)|int %}
	{% set amp = params.AMP|default(6.0)|float %}
	{% set feed = params.FEED|default(900)|float %}
	{ action_respond_info("PROBE_RECOVERY_PREPARE: ejecutando destrabe preventivo del probe") }
	DESTRABAR_BLTOUCH TARGET={target} CYCLES={cycles} AMP={amp} FEED={feed}
	{% endif %}

[gcode_macro MATERIAL_RUNTIME]
description = Estado runtime por material
variable_abs_fan_lock = 0
variable_material_name = ""
variable_upfila_abs_lock = 0
variable_temp_lock_active = 0
gcode = 
	{ action_respond_info("MATERIAL_RUNTIME: material=" ~ material_name ~ " abs_fan_lock=" ~ abs_fan_lock) }

[gcode_macro M106]
rename_existing = M406
description = Intercepta control de ventilador para bloquearlo en ABS
gcode = 
	{% set lock = printer["gcode_macro MATERIAL_RUNTIME"].abs_fan_lock|int %}
	{% set speed = params.S|default(255)|float %}
	
	{% if lock == 1 and speed > 0 %}
	{ action_respond_info("M106 omitido: bloqueo de ventilador activo para ABS") }
	M406 S0
	{% else %}
	M406 {rawparams}
	{% endif %}

[gcode_macro M107]
rename_existing = M407
description = Comando fan off compatible con bloqueo ABS
gcode = 
	M407

[gcode_macro SET_UPFILA_ABS_LOCK]
description = Habilita/deshabilita bloqueo de ventilador para ABS UP FILA (spool
gcode = 
	{% set enable = params.ENABLE|default(0)|int %}
	SET_GCODE_VARIABLE MACRO=MATERIAL_RUNTIME VARIABLE=upfila_abs_lock VALUE={enable}
	{ action_respond_info("UPFILA_ABS_LOCK: " ~ enable) }

[gcode_macro M140]
rename_existing = M140.1
description = Override M140 para evitar que el slicer cambie la cama cuando se usa Spoolman/Generic
gcode = 
	{% set state = printer.print_stats.state|string|lower %}
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|int %}
	{% set material = printer["gcode_macro MATERIAL_RUNTIME"].material_name|string|upper %}
	{% set lock_active = printer["gcode_macro MATERIAL_RUNTIME"].temp_lock_active|default(0)|int %}
	{% set use_spoolman = (synced == 1 and lock_active == 1) %}
	{% set target = params.S|default(-1)|float %}
	{% if target <= 0 %}
	
	M140.1 {rawparams}
	{% elif state == "printing" and use_spoolman %}
	{ action_respond_info("M140 ignorado (Spoolman activo): cama fija") }
	{% else %}
	M140.1 {rawparams}
	{% endif %}

[gcode_macro M190]
rename_existing = M190.1
description = Override M190 para evitar que el slicer cambie la cama cuando se usa Spoolman/Generic
gcode = 
	{% set state = printer.print_stats.state|string|lower %}
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|int %}
	{% set material = printer["gcode_macro MATERIAL_RUNTIME"].material_name|string|upper %}
	{% set lock_active = printer["gcode_macro MATERIAL_RUNTIME"].temp_lock_active|default(0)|int %}
	{% set use_spoolman = (synced == 1 and lock_active == 1) %}
	{% set target = params.S|default(-1)|float %}
	{% if target <= 0 %}
	M190.1 {rawparams}
	{% elif state == "printing" and use_spoolman %}
	{ action_respond_info("M190 ignorado (Spoolman activo): cama fija") }
	{% else %}
	M190.1 {rawparams}
	{% endif %}

[gcode_macro M104]
rename_existing = M104.1
description = Override M104 para evitar que el slicer cambie la boquilla cuando se usa Spoolman/Generic
gcode = 
	{% set state = printer.print_stats.state|string|lower %}
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|int %}
	{% set material = printer["gcode_macro MATERIAL_RUNTIME"].material_name|string|upper %}
	{% set lock_active = printer["gcode_macro MATERIAL_RUNTIME"].temp_lock_active|default(0)|int %}
	{% set use_spoolman = (synced == 1 and lock_active == 1) %}
	{% set target = params.S|default(-1)|float %}
	{% if target <= 0 %}
	
	M104.1 {rawparams}
	{% elif state == "printing" and use_spoolman %}
	{ action_respond_info("M104 ignorado (Spoolman activo): boquilla fija") }
	{% else %}
	M104.1 {rawparams}
	{% endif %}

[gcode_macro M109]
rename_existing = M109.1
description = Override M109 para evitar que el slicer cambie la boquilla cuando se usa Spoolman/Generic
gcode = 
	{% set state = printer.print_stats.state|string|lower %}
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|int %}
	{% set material = printer["gcode_macro MATERIAL_RUNTIME"].material_name|string|upper %}
	{% set lock_active = printer["gcode_macro MATERIAL_RUNTIME"].temp_lock_active|default(0)|int %}
	{% set use_spoolman = (synced == 1 and lock_active == 1) %}
	{% set target = params.S|default(-1)|float %}
	{% if target <= 0 %}
	M109.1 {rawparams}
	{% elif state == "printing" and use_spoolman %}
	{ action_respond_info("M109 ignorado (Spoolman activo): boquilla fija") }
	{% else %}
	M109.1 {rawparams}
	{% endif %}

[delayed_gcode DELAYED_PRINTER_OFF]
initial_duration = 0.
gcode = 
	{% if printer.idle_timeout.state == "Idle" %}
	{% if printer["extruder"].temperature > 50 %}
	UPDATE_DELAYED_GCODE ID=DELAYED_PRINTER_OFF DURATION=60
	{% else %}
	
	POWER_OFF_PRINTER
	{% endif %}
	{% else %}
	M118 Printer not idle, cancelled PRINTER_OFF.
	{% endif %}

[sdcard_loop]

[gcode_macro START_LOOP]
description = Compatibilidad con perfiles antiguos de Orca
gcode = 
	{ action_respond_info("START_LOOP en modo compatibilidad (sin loop de Klipper)") }

[gcode_macro STOP_LOOPING]
description = Compatibilidad con perfiles antiguos de Orca
gcode = 
	{ action_respond_info("STOP_LOOPING en modo compatibilidad (sin loop de Klipper)") }

[gcode_macro JOB_QUEUE_STATE]
description = Estado simple de transici?n de la cola Moonraker
variable_transition_active = 0
gcode = 
	{ action_respond_info("JOB_QUEUE_STATE transition_active=" ~ transition_active) }

[gcode_macro PRINT_FINISHED]
description = Cierre ligero; la transicion la maneja Moonraker Job Queue
gcode = 
	{ action_respond_info("Print finished") }

[gcode_macro QUEUE_TRANSITION]
description = Transicion entre trabajos del Job Queue (Moonraker): enfria a 45 C y luego empuja la pieza
gcode = 
	SET_GCODE_VARIABLE MACRO=JOB_QUEUE_STATE VARIABLE=transition_active VALUE=1
	{ action_respond_info("Queue: iniciando transicion...") }
	
	G91
	G1 Z5 F1800
	G90
	
	SET_GCODE_VARIABLE MACRO=COOLDOWN VARIABLE=extruder_temp VALUE=175
	SET_GCODE_VARIABLE MACRO=COOLDOWN VARIABLE=bed_temp VALUE=45
	COOLDOWN
	
	MANUAL_CLEAR_BED
	M400
	G4 P500
	SET_GCODE_VARIABLE MACRO=JOB_QUEUE_STATE VARIABLE=transition_active VALUE=0
	
	{ action_respond_info("Queue: transicion lista. Cargando siguiente trabajo...") }

[gcode_macro END_PRINT]
gcode = 
	{ action_respond_info("terminando...") }
	SET_GCODE_VARIABLE MACRO=JOB_QUEUE_STATE VARIABLE=transition_active VALUE=0
	
	
	SET_GCODE_VARIABLE MACRO=MATERIAL_RUNTIME VARIABLE=abs_fan_lock VALUE=0
	
	
	G91
	G1 E-2 F2700
	G1 E-2 Z0.2 F2400
	G90
	
	
	{% if "xyz" in printer.toolhead.homed_axes %}
	{% set x_park = (printer.toolhead.axis_maximum.x|float) / 2.0 %}
	{% set y_park = (printer.toolhead.axis_maximum.y|float) - 5.0 %}
	{% set z_now = printer.toolhead.position.z|float %}
	{% set z_max = printer.toolhead.axis_maximum.z|float %}
	{% set z_park = z_now + 10.0 %}
	{% if z_park > z_max %}
	{% set z_park = z_max %}
	{% endif %}
	
	G1 Z{z_park} F1200
	G1 X{x_park} Y{y_park} F6000
	{% endif %}
	
	
	
	M106 S0
	M104 S0
	M140 S0
	TURN_OFF_HEATERS

[gcode_macro PRINT_END]
description = End of printing
gcode = 
	END_PRINT

[gcode_macro FORCE_SPOOLMAN_SYNC]
description = Fuerza sincronizacion inmediata de Spoolman via gcode_shell_command
gcode = 
	{% if printer["gcode_shell_command spoolman_sync"] is defined %}
	RUN_SHELL_COMMAND CMD=spoolman_sync
	
	G4 P2500
	{% else %}
	{ action_respond_info("FORCE_SPOOLMAN_SYNC: sin shell_command en este fork, conservando estado actual") }
	
	G4 P5000
	{% endif %}

[gcode_macro SPOOLMAN_SYNC_AT_PRINT_START]
description = Dispara sincronización automática desde Moonraker (Spoolman -> Klipper)
gcode = 
	
	
	
	
	
	
	FORCE_SPOOLMAN_SYNC
	
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|default(0)|int %}
	{% set z_off = printer["gcode_macro SPOOLMAN_ACTIVE"].z_offset|default(0.0)|float %}
	{% set pa = printer["gcode_macro SPOOLMAN_ACTIVE"].pressure_advance|default(0.1)|float %}
	{% set fan_lock = printer["gcode_macro SPOOLMAN_ACTIVE"].fan_lock|default(0)|int %}
	
	{% if synced == 1 %}
	{ action_respond_info("✓ Spoolman sincronizado: z_offset=" ~ ("%+.3f" % z_off) ~ " pa=" ~ pa ~ " fan_lock=" ~ fan_lock) }
	{% else %}
	{ action_respond_info("⚠ Spoolman no sincronizado al inicio. Se aplicará fallback local de Z-offset.") }
	{% endif %}

[delayed_gcode SPOOLMAN_IDLE_SYNC_LOOP]
initial_duration = 0
gcode = 
	{% set state = printer.print_stats.state|string|lower %}
	{% if state != "printing" and state != "paused" %}
	SPOOLMAN_SYNC_AT_PRINT_START
	{% endif %}
	UPDATE_DELAYED_GCODE ID=SPOOLMAN_IDLE_SYNC_LOOP DURATION=60

[gcode_macro SPOOLMAN_ACTIVE]
description = Valores de temperatura sincronizados desde Spoolman
variable_nozzle_temp = 200.0
variable_bed_temp = 60.0
variable_remaining_g = 0.0
variable_vendor = ""
variable_filament_name = ""
variable_material = ""
variable_pressure_advance = 0.1
variable_z_offset = 0.0
variable_fan_lock = 0
variable_synced = 0
variable_initial_purge_distance = 100.0
gcode = 
	{ action_respond_info("Spoolman -> nozzle=" ~ nozzle_temp ~ " bed=" ~ bed_temp ~ " remaining_g=" ~ remaining_g ~ " vendor='" ~ vendor ~ "' name='" ~ filament_name ~ "' material='" ~ material ~ "' pa=" ~ pressure_advance ~ " synced=" ~ synced) }

[delayed_gcode RESTORE_SPOOLMAN_CACHE_ON_BOOT]
initial_duration = 2
gcode = 
	{% set svv = printer.save_variables.variables %}
	{% set cached_synced = svv['spoolman_cache_synced']|default(0)|int %}
	{% set cached_nozzle = svv['spoolman_cache_nozzle']|default(200.0)|float %}
	{% set cached_bed = svv['spoolman_cache_bed']|default(60.0)|float %}
	{% set cached_z = svv['spoolman_cache_z_offset']|default(0.0)|float %}
	{% set cached_pa = svv['spoolman_cache_pa']|default(0.1)|float %}
	{% set cached_fan = svv['spoolman_cache_fan_lock']|default(0)|int %}
	{% if printer["gcode_macro SPOOLMAN_ACTIVE"].synced|default(0)|int == 0 and cached_synced == 1 %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=nozzle_temp VALUE={cached_nozzle}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=bed_temp VALUE={cached_bed}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=z_offset VALUE={cached_z}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=pressure_advance VALUE={cached_pa}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=fan_lock VALUE={cached_fan}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=synced VALUE=1
	{ action_respond_info("SPOOLMAN cache restaurada tras reinicio: noz=" ~ cached_nozzle ~ " bed=" ~ cached_bed ~ " z_offset=" ~ ("%+.3f" % cached_z) ~ " pa=" ~ cached_pa ~ " fan_lock=" ~ cached_fan) }
	{% endif %}

[gcode_macro SYNC_SPOOLMAN_NOW]
description = Sincroniza datos del spool activo (temperaturas, identidad y PA)
gcode = 
	{% set has_nozzle = params.NOZZLE is defined %}
	{% set has_bed = params.BED is defined %}
	{% set has_remaining = params.REMAINING_G is defined %}
	{% set has_vendor = params.VENDOR is defined %}
	{% set has_name = params.FILAMENT_NAME is defined %}
	{% set has_material = params.MATERIAL is defined %}
	{% set has_pa = params.PRESSURE_ADVANCE is defined %}
	{% set has_z = params.Z_OFFSET is defined %}
	{% set has_fan = params.FAN_LOCK is defined %}
	{% set has_purge = params.INITIAL_PURGE_DISTANCE is defined %}
	{% set transition_active = printer["gcode_macro JOB_QUEUE_STATE"].transition_active|default(0)|int %}
	{% set allow_update = 1 if transition_active == 0 else 0 %}
	
	{% if not allow_update %}
	{ action_respond_info("SYNC_SPOOLMAN_NOW omitido: queue transition activa") }
	{% endif %}
	
	{% if allow_update and has_nozzle %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=nozzle_temp VALUE={params.NOZZLE|float}
	SAVE_VARIABLE VARIABLE=spoolman_cache_nozzle VALUE={params.NOZZLE|float}
	{% endif %}
	{% if allow_update and has_bed %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=bed_temp VALUE={params.BED|float}
	SAVE_VARIABLE VARIABLE=spoolman_cache_bed VALUE={params.BED|float}
	{% endif %}
	{% if allow_update and has_remaining %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=remaining_g VALUE={params.REMAINING_G|float}
	{% endif %}
	
	{% if allow_update and has_vendor %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=vendor VALUE='"{params.VENDOR|string|replace("\"", "")}"'
	{% endif %}
	{% if allow_update and has_name %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=filament_name VALUE='"{params.FILAMENT_NAME|string|replace("\"", "")}"'
	{% endif %}
	{% if allow_update and has_material %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=material VALUE='"{params.MATERIAL|string|replace("\"", "")}"'
	{% endif %}
	{% if allow_update and has_pa %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=pressure_advance VALUE={params.PRESSURE_ADVANCE|float}
	SAVE_VARIABLE VARIABLE=spoolman_cache_pa VALUE={params.PRESSURE_ADVANCE|float}
	{% endif %}
	{% if allow_update and has_z %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=z_offset VALUE={params.Z_OFFSET|float}
	SAVE_VARIABLE VARIABLE=spoolman_cache_z_offset VALUE={params.Z_OFFSET|float}
	{% endif %}
	{% if allow_update and has_fan %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=fan_lock VALUE={params.FAN_LOCK|int}
	SAVE_VARIABLE VARIABLE=spoolman_cache_fan_lock VALUE={params.FAN_LOCK|int}
	{% endif %}
	{% if allow_update and has_purge %}
	{% set purge_clamped = [0.0, [300.0, params.INITIAL_PURGE_DISTANCE|float]|min]|max %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=initial_purge_distance VALUE={purge_clamped}
	{% endif %}
	
	
	{% if allow_update and (has_nozzle or has_bed or has_remaining or has_pa or has_z or has_fan) %}
	SET_GCODE_VARIABLE MACRO=SPOOLMAN_ACTIVE VARIABLE=synced VALUE=1
	SAVE_VARIABLE VARIABLE=spoolman_cache_synced VALUE=1
	{% endif %}
	
	{% if allow_update and not has_nozzle and not has_bed and not has_remaining and not has_vendor and not has_name and not has_material and not has_pa and not has_z and not has_fan %}
	{ action_respond_info("Uso: SYNC_SPOOLMAN_NOW NOZZLE=<temp> BED=<temp> REMAINING_G=<g> PRESSURE_ADVANCE=<float> Z_OFFSET=<float> FAN_LOCK=<0|1>") }
	{% endif %}

[gcode_macro CHECK_FILAMENT_STOCK]
description = Chequeo informativo de material (no bloqueante)
gcode = 
	{% set required = params.REQUIRED_G|default(0)|float %}
	{% set required_mm = params.REQUIRED_MM|default(0)|float %}
	{% set diameter = params.FILAMENT_DIAMETER|default(1.75)|float %}
	{% set density = params.FILAMENT_DENSITY|default(1.24)|float %}
	{% set remaining = printer["gcode_macro SPOOLMAN_ACTIVE"].remaining_g|float %}
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|int %}
	
	{% if required <= 0 and required_mm > 0 and diameter > 0 and density > 0 %}
	{% set radius = diameter / 2.0 %}
	{% set volume_mm3 = 3.141592653589793 * radius * radius * required_mm %}
	{% set required = (volume_mm3 / 1000.0) * density %}
	{ action_respond_info("CHECK_FILAMENT_STOCK: REQUIRED_G no disponible, calculado desde mm/densidad = " ~ ("%.2f" % required) ~ "g") }
	{% endif %}
	
	{% if required <= 0 %}
	{ action_respond_info("CHECK_FILAMENT_STOCK: REQUIRED_G no definido, chequeo no bloqueante") }
	{% elif synced != 1 %}
	{ action_respond_info("CHECK_FILAMENT_STOCK: Spoolman no sincronizado, chequeo no bloqueante") }
	{% elif remaining < required %}
	{ action_respond_info("CHECK_FILAMENT_STOCK: advertencia, requerido=" ~ ("%.1f" % required) ~ "g disponible=" ~ ("%.1f" % remaining) ~ "g") }
	{% else %}
	{ action_respond_info("Material OK: requerido=" ~ required ~ "g disponible=" ~ remaining ~ "g") }
	{% endif %}

[gcode_macro FILAMENT_WATCHDOG]
description = Configura monitor de material por Spoolman (pausa por bajo stock)
variable_enabled = 1
variable_threshold_g = 3.0
variable_interval_s = 60
variable_tripped = 0
gcode = 
	{% if params.ENABLED is defined %}
	SET_GCODE_VARIABLE MACRO=FILAMENT_WATCHDOG VARIABLE=enabled VALUE={params.ENABLED|int}
	{% endif %}
	{% if params.THRESHOLD_G is defined %}
	SET_GCODE_VARIABLE MACRO=FILAMENT_WATCHDOG VARIABLE=threshold_g VALUE={params.THRESHOLD_G|float}
	{% endif %}
	{% if params.INTERVAL_S is defined %}
	SET_GCODE_VARIABLE MACRO=FILAMENT_WATCHDOG VARIABLE=interval_s VALUE={params.INTERVAL_S|int}
	{% endif %}
	{% if params.RESET is defined and params.RESET|int == 1 %}
	SET_GCODE_VARIABLE MACRO=FILAMENT_WATCHDOG VARIABLE=tripped VALUE=0
	{% endif %}
	{ action_respond_info("FILAMENT_WATCHDOG: enabled=" ~ enabled ~ " threshold_g=" ~ threshold_g ~ " interval_s=" ~ interval_s ~ " tripped=" ~ tripped) }

[delayed_gcode FILAMENT_WATCHDOG_LOOP]
initial_duration = 12
gcode = 
	{% set enabled = printer["gcode_macro FILAMENT_WATCHDOG"].enabled|int %}
	{% set threshold = printer["gcode_macro FILAMENT_WATCHDOG"].threshold_g|float %}
	{% set interval = printer["gcode_macro FILAMENT_WATCHDOG"].interval_s|int %}
	{% set tripped = printer["gcode_macro FILAMENT_WATCHDOG"].tripped|int %}
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|int %}
	{% set remaining = printer["gcode_macro SPOOLMAN_ACTIVE"].remaining_g|float %}
	{% set state = printer.print_stats.state|string|lower %}
	{% set idle_state = printer.idle_timeout.state|string|lower %}
	{% set is_printing = (state == "printing") or (idle_state == "printing") %}
	
	{% if enabled == 1 and synced == 1 %}
	{% if is_printing and remaining > 0 and remaining <= threshold and tripped == 0 %}
	SET_GCODE_VARIABLE MACRO=FILAMENT_WATCHDOG VARIABLE=tripped VALUE=1
	RESPOND TYPE=command MSG="action:prompt_begin Material bajo"
	RESPOND TYPE=command MSG='{"action:prompt_text Quedan %.1fg (umbral %.1fg). Cambia el material y reanuda." % (remaining, threshold)}'
	RESPOND TYPE=command MSG="action:prompt_footer_button Cerrar|RESPOND TYPE=command MSG=action:prompt_end|secondary"
	RESPOND TYPE=command MSG="action:prompt_footer_button Reanudar|RESUME|primary"
	RESPOND TYPE=command MSG="action:prompt_show"
	{ action_respond_info("FILAMENT_WATCHDOG: material bajo, pausando impresion") }
	PAUSE
	{% elif tripped == 1 and remaining > (threshold + 0.2) %}
	SET_GCODE_VARIABLE MACRO=FILAMENT_WATCHDOG VARIABLE=tripped VALUE=0
	{ action_respond_info("FILAMENT_WATCHDOG: stock recuperado, monitor rearmado") }
	{% endif %}
	{% endif %}
	
	{% if interval < 10 %}
	UPDATE_DELAYED_GCODE ID=FILAMENT_WATCHDOG_LOOP DURATION=10
	{% else %}
	UPDATE_DELAYED_GCODE ID=FILAMENT_WATCHDOG_LOOP DURATION={interval}
	{% endif %}

[gcode_macro START_PRINT]
gcode = 
	
	
	
	{% if printer["gcode_macro SPOOLMAN_SYNC_AT_PRINT_START"] is defined %}
	SPOOLMAN_SYNC_AT_PRINT_START
	{% endif %}
	
	
	G1 Z50.0 F1000
	
	
	
	{% set profile_hint = params.FILAMENT_PROFILE|default(params.FILAMENT_TYPE|default(params.MATERIAL_TYPE|default("")))|string %}
	{% set profile_l = profile_hint|lower|trim %}
	{% set profile_u = profile_hint|upper|trim %}
	{% set sp_synced_early = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|default(0)|int %}
	{% set use_spoolman = (profile_l == "generic" or profile_l.startswith("generic ")) or (params.USE_SPOOLMAN|default(0)|int == 1) or (sp_synced_early == 1) %}
	{% set BED_TEMP = params.BED_TEMP|default(55)|float %}
	{% set EXTRUDER_TEMP = params.EXTRUDER_TEMP|default(220)|float %}
	{% set purge_mm = printer["gcode_macro SPOOLMAN_ACTIVE"].initial_purge_distance|default(100.0)|float %}
	{% if purge_mm < 0.0 %}{% set purge_mm = 0.0 %}{% endif %}
	{% if purge_mm > 300.0 %}{% set purge_mm = 300.0 %}{% endif %}
	
	{% set sp_synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|default(0)|int %}
	{% set sp_pa = printer["gcode_macro SPOOLMAN_ACTIVE"].pressure_advance|default(-1.0)|float %}
	{% set sp_fan_lock = printer["gcode_macro SPOOLMAN_ACTIVE"].fan_lock|default(0)|int %}
	{% set sp_zoff = printer["gcode_macro SPOOLMAN_ACTIVE"].z_offset|default(0.0)|float %}
	{% set abs_fan_lock = 1 if (use_spoolman and sp_fan_lock == 1) else 0 %}
	
	{% if use_spoolman and sp_pa >= 0 %}
	SET_PRESSURE_ADVANCE ADVANCE={sp_pa}
	{ action_respond_info("Spoolman PA aplicado: " ~ sp_pa) }
	{% endif %}
	{% if abs_fan_lock == 1 %}
	{ action_respond_info("Fan-lock activo desde Spoolman (fan_lock=1)") }
	{% endif %}
	{ action_respond_info("Spoolman z_offset reportado: " ~ ("%+.3f" % sp_zoff)) }
	
	
	
	
	SET_GCODE_VARIABLE MACRO=MATERIAL_RUNTIME VARIABLE=abs_fan_lock VALUE={abs_fan_lock}
	SET_GCODE_VARIABLE MACRO=MATERIAL_RUNTIME VARIABLE=temp_lock_active VALUE=0
	{% set runtime_material = "GENERIC" if use_spoolman else profile_hint %}
	SET_GCODE_VARIABLE MACRO=MATERIAL_RUNTIME VARIABLE=material_name VALUE='"{runtime_material}"'
	{% if abs_fan_lock == 1 %}
	M107
	{ action_respond_info("ABS detectado: ventilacion de capa bloqueada (M106 omitido)") }
	{% endif %}
	
	
	APPLY_MATERIAL_Z_OFFSET
	
	
	SET_GCODE_VARIABLE MACRO=FILAMENT_WATCHDOG VARIABLE=tripped VALUE=0
	UPDATE_DELAYED_GCODE ID=FILAMENT_WATCHDOG_LOOP DURATION=5
	{% if use_spoolman %}
	{% set sp_bed = printer["gcode_macro SPOOLMAN_ACTIVE"].bed_temp|float %}
	{% set sp_noz = printer["gcode_macro SPOOLMAN_ACTIVE"].nozzle_temp|float %}
	{% set sp_default = (sp_bed == 60.0 and sp_noz == 200.0) %}
	{% set orca_non_default = (BED_TEMP != 60.0 or EXTRUDER_TEMP != 200.0) %}
	{% if sp_default and orca_non_default %}
	{ action_respond_info("START_PRINT Generic detectado, pero Spoolman no sincronizado (200/60). Manteniendo Orca: cama=" ~ BED_TEMP ~ " / boquilla=" ~ EXTRUDER_TEMP) }
	{% else %}
	{% if sp_bed > 0 %}{% set BED_TEMP = sp_bed %}{% endif %}
	{% if sp_noz > 0 %}{% set EXTRUDER_TEMP = sp_noz %}{% endif %}
	{ action_respond_info("START_PRINT usando Spoolman (Generic): " ~ profile_hint ~ " cama=" ~ BED_TEMP ~ " / boquilla=" ~ EXTRUDER_TEMP) }
	{% endif %}
	{% else %}
	{ action_respond_info("START_PRINT usando temperaturas de Orca: " ~ profile_hint ~ " cama=" ~ BED_TEMP ~ " / boquilla=" ~ EXTRUDER_TEMP) }
	{% endif %}
	
	
	
	PROBE_RECOVERY_PREPARE TARGET={EXTRUDER_TEMP}
	
	
	M220 S100
	M221 S100
	
	
	M140 S{BED_TEMP}
	
	
	G28
	
	G92 E0
	
	
	BED_MESH_CALIBRATE PROFILE="current"
	
	G1 Z2.0 F3000
	G1 X-2.1 Y20 Z1 F5000.0
	
	
	M190 S{BED_TEMP}
	
	M109 S{EXTRUDER_TEMP}
	SET_GCODE_VARIABLE MACRO=MATERIAL_RUNTIME VARIABLE=temp_lock_active VALUE=1
	{ action_respond_info("Temp-lock Spoolman activo para el resto de la impresion") }
	
	
	G1 X-17 Y80 Z10 F3000
	{ action_respond_info("Purga inicial Spoolman: " ~ ("%.1f" % purge_mm) ~ " mm @7.0 mm/s") }
	G1 E{purge_mm} F420
	
	G92 E0
	G1 E-1.0000 F500
	
	G1 E0.0000 F1800

[gcode_macro WIPE_OUT]
gcode = 
	G91
	G1 E-2 F2700
	G1 E-2 Z0.2 F2400
	G1 X5 Y5 F3000
	G1 Z10
	G90
	G1 X0 Y225

[gcode_macro COOLDOWN]
variable_extruder_temp = 0
variable_bed_temp = 0
gcode = 
	{% if printer["gcode_macro COOLDOWN"].extruder_temp > 0 and printer["gcode_macro COOLDOWN"].bed_temp > 0 %}
	{ action_respond_info("Enfriando...") }
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={ printer["gcode_macro COOLDOWN"].extruder_temp }
	SET_HEATER_TEMPERATURE HEATER=heater_bed TARGET={ printer["gcode_macro COOLDOWN"].bed_temp }
	TEMPERATURE_WAIT SENSOR=heater_bed MAXIMUM={ printer["gcode_macro COOLDOWN"].bed_temp + 1}
	{% endif %}

[gcode_macro MANUAL_CLEAR_BED]
gcode = 
	{ action_respond_info("Retirando pieza...") }
	G90
	G1 X120.0 Y230.0 Z1.0 F3000
	G1 Y0.0 F3000
	G1 Y20.0 F3000
	G1 X0.0 F3000
	G1 Y150.0 F3000
	G1 Y0.0 F3000

[gcode_macro PID_EXTRUDER]
gcode = 
	PID_CALIBRATE HEATER=extruder TARGET=210
	SAVE_CONFIG

[gcode_macro PID_BED]
gcode = 
	PID_CALIBRATE HEATER=heater_bed TARGET=60
	SAVE_CONFIG

[gcode_macro FILAMENT_LOAD]
gcode = 
	{% set load = params.L|default(100)|float * 0.5 %}
	{% set extruder_temp = params.T|default(210)|float %}
	SAVE_GCODE_STATE NAME=FILAMENT_LOAD_STATE
	LOW_TEMP_CHECK T={extruder_temp}
	M118 Loading filament
	M83
	G1 E{load} F1500
	G4 P1000
	G1 E{load} F200
	RESTORE_GCODE_STATE NAME=FILAMENT_LOAD_STATE
	BEEP

[gcode_macro FILAMENT_UNLOAD]
gcode = 
	{% set unload = params.U|default(100)|float %}
	{% set extruder_temp = params.T|default(200)|float %}
	SAVE_GCODE_STATE NAME=FILAMENT_UNLOAD_STATE
	LOW_TEMP_CHECK T={extruder_temp}
	M118 Unloading filament
	M83
	G1 E2 F200
	G1 E-10 F200
	G1 E-{unload} F1500
	RESTORE_GCODE_STATE NAME=FILAMENT_UNLOAD_STATE

[gcode_macro LOW_TEMP_CHECK]
gcode = 
	{% set extruder_temp = params.T|default(200)|float %}
	{% if printer.extruder.target > extruder_temp %}
	{% set extruder_temp = printer.extruder.target %}
	{% endif %}
	{% if printer.extruder.temperature < extruder_temp %}
	M118 Heating to {extruder_temp}
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={extruder_temp}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={extruder_temp}
	{% endif %}

[gcode_macro calibrar_punta]
description = calibra z offset
gcode = 
	PROBE_RECOVERY_PREPARE
	PRTOUCH_PROBE_ZOFFSET

[gcode_macro EXTRAER_MATERIAL]
description = extrae material con temperatura de spoolman (o T manual) con limites seguros
gcode = 
	{% set synced = printer["gcode_macro SPOOLMAN_ACTIVE"].synced|default(0)|int %}
	{% set spool_temp = printer["gcode_macro SPOOLMAN_ACTIVE"].nozzle_temp|default(0)|float %}
	{% set manual_t = params.T|default(-1)|float %}
	{% set max_nozzle = printer.configfile.settings.extruder.max_temp|default(260)|float %}
	{% set safe_cap = max_nozzle - 5.0 %}
	{% set auto_cool = params.COOL|default(1)|int %}
	{% if manual_t > 0 %}
	{% set extruder_temp = manual_t %}
	{% elif synced == 1 and spool_temp > 0 %}
	{% set extruder_temp = spool_temp %}
	{% else %}
	{% set extruder_temp = 200.0 %}
	{% endif %}
	{% if extruder_temp < 160.0 %}
	{% set extruder_temp = 160.0 %}
	{% endif %}
	{% if extruder_temp > safe_cap %}
	{% set extruder_temp = safe_cap %}
	{% endif %}
	{% set unload = params.U|default(120)|float %}
	SAVE_GCODE_STATE NAME=EXTRAER_MATERIAL_STATE
	LOW_TEMP_CHECK T={extruder_temp}
	M118 Extrayendo material a {extruder_temp}C (spool={spool_temp}C, synced={synced}, cap={safe_cap}C)
	M83
	G1 E2 F200
	G1 E-10 F200
	G1 E-{unload} F1500
	RESTORE_GCODE_STATE NAME=EXTRAER_MATERIAL_STATE
	{% if auto_cool == 1 and printer.print_stats.state|string|lower != "printing" %}
	M104 S0
	M118 Extrusor apagado al finalizar EXTRAER_MATERIAL
	{% else %}
	M118 Extrusor se mantiene caliente (COOL={auto_cool})
	{% endif %}

[filter]

[dirzctl]

[hx711s]
sensor0_clk_pin = PA4
sensor0_sdo_pin = PC6

[prtouch]
sensor_x = 21
sensor_y = 30
clr_noz_start_x = 15
clr_noz_start_y = 25
clr_noz_len_y = 15
s_hot_min_temp = 160
s_hot_max_temp = 200
s_bed_max_temp = 60
show_msg = True
wipe_retract_distance = 2

[filament_switch_sensor FilamentSensor]
switch_pin = ^PC15
pause_on_runout = True
pause_delay = 3.0
runout_gcode = PAUSE

[exclude_object]

[force_move]
enable_force_move = true

[idle_timeout]
timeout = 99999

[save_variables]
filename = /home/pi/printer_data/config/variables.cfg

[stepper_x]
step_pin = PC2
dir_pin = !PB9
enable_pin = !PC3
microsteps = 64
rotation_distance = 40
endstop_pin = !PA5
position_endstop = -17
position_min = -17
position_max = 219
homing_speed = 50

[stepper_y]
step_pin = PB8
dir_pin = PB7
enable_pin = !PC3
microsteps = 64
rotation_distance = 40
endstop_pin = !PA6
position_endstop = -11
position_min = -11
position_max = 230
homing_speed = 50

[stepper_z]
step_pin = PB6
dir_pin = !PB5
enable_pin = !PC3
microsteps = 16
rotation_distance = 8
endstop_pin = probe:z_virtual_endstop
position_min = -2
position_max = 250
homing_speed = 4
second_homing_speed = 1
homing_retract_dist = 2.0

[tmc2209 stepper_x]
uart_pin = PB12
run_current = 0.60
sense_resistor = 0.150
stealthchop_threshold = 0
interpolate = false

[tmc2209 stepper_y]
uart_pin = PB13
run_current = 0.60
sense_resistor = 0.150
stealthchop_threshold = 0
interpolate = false

[tmc2209 stepper_z]
uart_pin = PB14
run_current = 0.8
sense_resistor = 0.150
stealthchop_threshold = 0
interpolate = false

[firmware_retraction]
retract_length = 1.2
retract_speed = 40
unretract_extra_length = 0.02
unretract_speed = 30

[extruder]
max_extrude_only_distance = 300.0
max_extrude_only_velocity = 7
pressure_advance = 0.1
step_pin = PB4
dir_pin = PB3
enable_pin = !PC3
microsteps = 16
rotation_distance = 7.44
nozzle_diameter = 0.400
filament_diameter = 1.750
heater_pin = PA1
sensor_type = EPCOS 100K B57560G104F
sensor_pin = PC5
control = pid
pid_kp = 27.142
pid_ki = 1.371
pid_kd = 134.351
min_extrude_temp = 50
min_temp = 0
max_temp = 350

[heater_bed]
heater_pin = PB2
sensor_type = EPCOS 100K B57560G104F
sensor_pin = PC4
control = pid
pid_kp = 66.371
pid_ki = 0.846
pid_kd = 1301.702
min_temp = 0
max_temp = 150

[heater_fan hotend_fan]
pin = PC1
max_power = 1.0
shutdown_speed = 0
cycle_time = 0.010
hardware_pwm = false
kick_start_time = 0.100
off_below = 0.0
heater = extruder
heater_temp = 50
fan_speed = 1.0

[fan]
pin = PA0

[mcu]
serial = /dev/serial/by-id/usb-1a86_USB_Serial-if00-port0
restart_method = command

[printer]
kinematics = cartesian
max_velocity = 250
max_accel = 2500
max_z_velocity = 5
square_corner_velocity = 5.0
max_z_accel = 100

[bltouch]
sensor_pin = ^PC14
control_pin = PC13
x_offset = -23.0
y_offset = -14.5
speed = 20
pin_move_time = 0.4
stow_on_each_sample = False
probe_with_touch_mode = True
z_offset = 1.807

[safe_z_home]
home_xy_position = 140,150
speed = 50
z_hop = 10
z_hop_speed = 5

[bed_mesh]
speed = 120
horizontal_move_z = 5
mesh_min = 30,30
mesh_max = 190,190
probe_count = 10,10
algorithm = bicubic

[output_pin beeper]
pin = PB0

[screws_tilt_adjust]
screw1 = 54.5, 45.5
screw1_name = front left screw
screw2 = 224.5, 45.5
screw2_name = front right screw
screw3 = 224.5, 215.5
screw3_name = rear right screw
screw4 = 54.5, 215.5
screw4_name = rear left screw
horizontal_move_z = 10.
speed = 50.
screw_thread = CCW-M4

[temperature_sensor mcu_temp]
sensor_type = temperature_mcu
min_temp = 0
max_temp = 100

[temperature_sensor Orange_Pi]
sensor_type = temperature_host
min_temp = 10
max_temp = 100

[e3v3se_display]
language = spanish
logging = False

[e3v3se_display MACRO1]
gcode = calibrar_punta
label = Calibrar punta
icon = 12

[e3v3se_display MACRO2]
gcode = G28
label = Home all
icon = 29

[e3v3se_display MACRO3]
gcode = PID_EXTRUDER
label = PID boquilla
icon = 14

[e3v3se_display MACRO4]
gcode = PID_BED
label = PID cama
icon = 14

[e3v3se_display MACRO5]
gcode = EXTRAER_MATERIAL
label = Extraer material
icon = 9

[e3v3se_display MACRO6]
gcode = MANUAL_CLEAR_BED
label = Limpiar cama
icon = 9

